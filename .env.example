# .env.example — 복사해서 .env로 사용

# Data directory (SQLite 파일들)
DATA_DIRECTORY=./data

# Claude API (내부 프록시 경유)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# 내부 프록시가 있으면 설정 (없으면 비워두기)
# ANTHROPIC_BASE_URL=http://llm-proxy.internal:8080

# App
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Correlator
MATCH_WINDOW_SECONDS=60
CORRELATOR_POLL_INTERVAL=2.0
STALE_EDGE_DAYS=7

# Skills
SKILLS_DIRECTORY=./skills
